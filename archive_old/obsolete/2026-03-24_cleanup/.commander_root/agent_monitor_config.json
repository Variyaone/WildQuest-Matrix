{
  "warning_threshold_hours": 6,
  "critical_threshold_hours": 12,
  "timeout_threshold_hours": 24,
  "task_timeout_minutes": 240,
  "agents_to_monitor": [
    "main",
    "researcher",
    "architect",
    "creator",
    "critic"
  ],
  "warning_timeout_minutes": 120,
  "critical_timeout_minutes": 240,
  "fatal_timeout_minutes": 480,
  "auto_mark_timeout": true,
  "auto_reassign": false,
  "backup_before_modify": true,
  "agent_fallback_map": {
    "researcher": ["architect", "creator"],
    "architect": ["researcher", "creator"],
    "creator": ["researcher", "architect"],
    "critic": ["researcher"],
    "main": ["researcher", "architect"]
  }
}
