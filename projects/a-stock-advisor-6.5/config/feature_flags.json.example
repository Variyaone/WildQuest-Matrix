{
  "version": "1.1.0",
  "last_updated": "2026-03-20",
  "user_scenario": "enterprise",
  "features": {
    "data_engineering": {
      "enabled": true,
      "auto_update": true,
      "multi_source": true,
      "data_quality": true,
      "description": "数据工程模块"
    },
    "factor_research": {
      "enabled": true,
      "auto_mining": true,
      "factor_validation": true,
      "description": "因子研发模块"
    },
    "strategy_development": {
      "enabled": true,
      "description": "策略开发模块"
    },
    "backtest_verification": {
      "enabled": true,
      "complex_engine": true,
      "description": "回测验证模块"
    },
    "live_trading": {
      "enabled": true,
      "paper_trading_only": true,
      "auto_execution": true,
      "description": "实盘工程模块"
    },
    "system_management": {
      "enabled": true,
      "description": "系统管理模块"
    },
    "push_system": {
      "enabled": true,
      "feishu_enabled": true,
      "description": "推送系统"
    },
    "risk_control": {
      "enabled": true,
      "strict_mode": true,
      "description": "风控系统"
    },
    "ml_factor_combiner": {
      "enabled": true,
      "model_type": "gbdt",
      "description": "ML因子组合器"
    },
    "dynamic_factor_weight": {
      "enabled": true,
      "rolling_window": 20,
      "description": "动态因子权重系统"
    },
    "rdagent": {
      "enabled": true,
      "fallback_to_local": true,
      "use_mock": true,
      "api_key": "YOUR_API_KEY_HERE",
      "base_url": "https://integrate.api.nvidia.com/v1",
      "model": "z-ai/glm4.7",
      "description": "RDAgent因子挖掘 - 配置API Key后设置use_mock为false"
    },
    "event_engine": {
      "enabled": true,
      "description": "事件驱动引擎"
    },
    "infrastructure": {
      "enabled": true,
      "rbac": false,
      "encryption": false,
      "audit": true,
      "lineage": true,
      "data_bus": true,
      "contract_validation": true,
      "description": "基础设施模块"
    },
    "monitoring": {
      "enabled": true,
      "attribution": true,
      "iteration": true,
      "description": "监控模块"
    }
  }
}
