{
  "version": "1.0",
  "templates": {
    "full": {
      "name": "全功能",
      "description": "获得所有工具权限（session/system工具除外）",
      "tools": {
        "profile": "full"
      }
    },
    "researcher": {
      "name": "研究员",
      "description": "数据分析 + 网络研究",
      "tools": {
        "allow": [
          "read",
          "write",
          "edit",
          "exec",
          "process",
          "web_search",
          "web_fetch",
          "browser",
          "canvas",
          "memory_search",
          "memory_get"
        ]
      }
    },
    "architect": {
      "name": "架构师",
      "description": "架构设计 + 代码实现",
      "tools": {
        "profile": "coding",
        "allow": [
          "read",
          "write",
          "edit",
          "exec",
          "process",
          "web_search",
          "web_fetch"
        ]
      }
    },
    "creator": {
      "name": "创作者",
      "description": "文档 + 代码生成，继承architect",
      "inherits": "architect",
      "tools": {
        "allow": [
          "read",
          "write",
          "edit",
          "exec",
          "web_search",
          "web_fetch"
        ]
      }
    },
    "critic": {
      "name": "评审官",
      "description": "只读 + 审核，无执行权限",
      "tools": {
        "profile": "coding",
        "allow": [
          "read",
          "write",
          "edit",
          "web_search"
        ]
      }
    },
    "minimal": {
      "name": "最小权限",
      "description": "仅读 + 网络搜索（测试/临时使用）",
      "tools": {
        "allow": [
          "read",
          "web_search",
          "web_fetch"
        ]
      }
    }
  },
  "agents": {
    "main": {
      "template": "custom",
      "tools": {}
    },
    "researcher": {
      "template": "researcher",
      "tools": {
        "template": "researcher"
      }
    },
    "architect": {
      "template": "architect",
      "tools": {
        "template": "architect"
      }
    },
    "creator": {
      "template": "creator",
      "tools": {
        "template": "creator"
      }
    },
    "critic": {
      "template": "critic",
      "tools": {
        "template": "critic"
      }
    },
    "innovator": {
      "template": "custom",
      "tools": {
        "profile": "full"
      }
    }
  }
}